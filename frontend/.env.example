# Backend URL used by the Vite dev-server proxy (development only).
# Change this if your backend runs on a different host or port.
BACKEND_URL=http://localhost:8000

# Base URL prepended to all API requests in the browser (production builds).
# Leave empty in development — the Vite proxy handles routing to the backend.
# Set to the full backend origin for production, e.g. https://api.example.com
VITE_API_BASE_URL=
